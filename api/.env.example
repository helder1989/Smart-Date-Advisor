APP_NAME=SmartDataAdvisor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=

SESSION_DRIVER=array
QUEUE_CONNECTION=sync

CACHE_STORE=redis
CACHE_PREFIX=sda_

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# Claude API (Anthropic)
# -------------------------------------------------------
CLAUDE_API_KEY=

# -------------------------------------------------------
# Onfly API
# -------------------------------------------------------
ONFLY_CLIENT_ID=
ONFLY_CLIENT_SECRET=
ONFLY_API_BASE=https://api.onfly.com.br
ONFLY_GATEWAY_URL=https://gateway.viagens.dev

# -------------------------------------------------------
# Dev / Debug
# -------------------------------------------------------
# Token fixo usado em ambiente local (evita o fluxo de login OAuth).
# Deixe vazio em produção.
TOKEN_DEV=
